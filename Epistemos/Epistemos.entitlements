<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- ═══════════════════════════════════════════════════════════════
	     App Sandbox: ENABLED for App Store distribution.
	     Specific exceptions below for Omega agent capabilities.
	     ═══════════════════════════════════════════════════════════════ -->
	<key>com.apple.security.app-sandbox</key>
	<true/>

	<!-- ── File Access ────────────────────────────────────────────── -->

	<!-- User-selected files (vault folder via NSOpenPanel) persist across launches -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>

	<!-- Bookmarks: persist file access across app restarts (security-scoped bookmarks) -->
	<key>com.apple.security.files.bookmarks.app-scope</key>
	<true/>

	<!-- Downloads folder: common vault location -->
	<key>com.apple.security.files.downloads.read-write</key>
	<true/>

	<!-- ── Network ────────────────────────────────────────────────── -->

	<!-- Outbound network: cloud LLM APIs (OpenAI, Anthropic, Google), model downloads -->
	<key>com.apple.security.network.client</key>
	<true/>

	<!-- ── Automation / Scripting ──────────────────────────────────── -->

	<!-- Apple Events: Omega agent sends Apple Events to automate other apps -->
	<key>com.apple.security.automation.apple-events</key>
	<true/>

	<!-- Scripting targets: Omega's SafariAgent and AutomationAgent use osascript -->
	<key>com.apple.security.scripting-targets</key>
	<dict>
		<!-- Safari automation (open URLs, get page info) -->
		<key>com.apple.Safari</key>
		<array>
			<string>com.apple.Safari.scripting</string>
		</array>
		<!-- System Events: UI automation, click elements, key presses -->
		<key>com.apple.systemevents</key>
		<array>
			<string>com.apple.systemevents.processes</string>
		</array>
		<!-- Finder: file operations -->
		<key>com.apple.finder</key>
		<array>
			<string>com.apple.finder.scripting</string>
		</array>
		<!-- Shortcuts: run Shortcuts.app workflows -->
		<key>com.apple.shortcuts</key>
		<array>
			<string>com.apple.shortcuts.run</string>
		</array>
	</dict>

	<!-- ── Process Execution ─────────────────────────────────────── -->

	<!-- Knowledge Fusion: execute Python/pip for MLX training environment setup -->
	<key>com.apple.security.temporary-exception.files.absolute-path.read-write</key>
	<array>
		<string>/opt/homebrew/</string>
		<string>/usr/local/</string>
	</array>

	<!-- ── Hardened Runtime Exceptions (for local MLX inference) ── -->

	<!-- JIT compilation: Metal/MLX shader compilation -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>

	<!-- Unsigned memory: MLX model weight loading and inference buffers -->
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>

	<!-- Library validation: load Rust FFI dylibs (graph-engine, omega-ax, omega-mcp) -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>

	<!-- ── Device Access ──────────────────────────────────────────── -->

	<!-- Camera: not needed currently, future potential for document scanning -->

	<!-- ── App Groups ─────────────────────────────────────────────── -->
	<!-- Add when implementing widgets or extensions:
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.epistemos.app</string>
	</array>
	-->
</dict>
</plist>
