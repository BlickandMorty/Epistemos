<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- ═══════════════════════════════════════════════════════════════
	     App Sandbox: DISABLED for debug builds.
	     Enables Knowledge Fusion Python environment setup (Homebrew, pip, venv)
	     and Omega agent capabilities without sandbox restrictions.
	     Release builds use Epistemos.entitlements with sandbox ENABLED.
	     ═══════════════════════════════════════════════════════════════ -->
	<key>com.apple.security.app-sandbox</key>
	<false/>

	<!-- ── Hardened Runtime Exceptions (for local MLX inference) ── -->

	<!-- JIT compilation: Metal/MLX shader compilation -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>

	<!-- Unsigned memory: MLX model weight loading and inference buffers -->
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>

	<!-- Library validation: load Rust FFI dylibs (graph-engine, omega-ax, omega-mcp, epistemos-core) -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
</dict>
</plist>
