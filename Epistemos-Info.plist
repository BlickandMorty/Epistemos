<plist version="1.0">
<dict>
	<key>ATSApplicationFontsPath</key>
	<string>Resources/Fonts</string>
	<key>CFBundleIdentifier</key>
	<string>com.epistemos.app</string>
	<key>CFBundleIconName</key>
	<string>AppIcon</string>
	<key>CFBundleVersion</key>
	<string>1</string>
