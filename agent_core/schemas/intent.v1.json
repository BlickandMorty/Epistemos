{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "epistemos://schemas/intent.v1.json",
  "title": "Agent intent",
  "description": "Plan §8 — the LLM never mutates state; it emits an Intent. The runtime applies the Effect. Discriminated by `action` field.",
  "type": "object",
  "required": ["action"],
  "oneOf": [
    {
      "type": "object",
      "required": ["action", "path", "body", "frontmatter"],
      "additionalProperties": false,
      "properties": {
        "action": { "const": "vault.write" },
        "path": { "type": "string", "minLength": 1 },
        "body": { "type": "string" },
        "frontmatter": { "type": "object" }
      }
    },
    {
      "type": "object",
      "required": ["action", "from", "to"],
      "additionalProperties": false,
      "properties": {
        "action": { "const": "vault.move" },
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 }
      }
    },
    {
      "type": "object",
      "required": ["action", "path"],
      "additionalProperties": false,
      "properties": {
        "action": { "const": "vault.delete" },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    {
      "type": "object",
      "required": ["action", "canonical_name", "definition"],
      "additionalProperties": false,
      "properties": {
        "action": { "const": "concept.create" },
        "canonical_name": { "type": "string", "pattern": "^[a-z0-9-]{2,64}$" },
        "definition": { "type": "string", "minLength": 1 }
      }
    },
    {
      "type": "object",
      "required": ["action", "canonical_name", "alias"],
      "additionalProperties": false,
      "properties": {
        "action": { "const": "concept.alias" },
        "canonical_name": { "type": "string", "pattern": "^[a-z0-9-]{2,64}$" },
        "alias": { "type": "string", "minLength": 1 }
      }
    },
    {
      "type": "object",
      "required": ["action", "entry"],
      "additionalProperties": false,
      "properties": {
        "action": { "const": "memory.write" },
        "entry": { "type": "object" }
      }
    },
    {
      "type": "object",
      "required": ["action", "reason"],
      "additionalProperties": false,
      "properties": {
        "action": { "const": "noop" },
        "reason": { "type": "string", "minLength": 1, "maxLength": 280 }
      }
    },
    {
      "type": "object",
      "required": ["action", "reason"],
      "additionalProperties": false,
      "properties": {
        "action": { "const": "abort" },
        "reason": { "type": "string", "minLength": 1, "maxLength": 280 }
      }
    }
  ]
}
