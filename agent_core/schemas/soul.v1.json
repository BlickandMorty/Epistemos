{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "epistemos://schemas/soul.v1.json",
  "title": "Agent soul (.soul.json half)",
  "description": "Plan §2.3 — agent persistent identity. Pairs with `<name>.soul.md` (narrative half). The pair is bidirectionally linked via `narrative_path` (json side) and `soul_id` in markdown frontmatter (md side). Orphans (one half missing or pair mismatch) are rejected at load time.",
  "type": "object",
  "required": ["$schema", "id", "name", "version", "narrative_path", "schema_version"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "const": "epistemos://schemas/soul.v1.json" },
    "id": {
      "type": "string",
      "pattern": "^soul\\.[a-z0-9_-]+\\.v[0-9]+$",
      "description": "Stable id like `soul.router.v1`."
    },
    "name": { "type": "string", "minLength": 1 },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semver; bump on persona / capability change."
    },
    "narrative_path": {
      "type": "string",
      "pattern": "\\.soul\\.md$",
      "description": "Sibling .soul.md path (relative)."
    },
    "model_preference": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "primary":     { "$ref": "#/$defs/modelPick" },
        "fallback":    { "$ref": "#/$defs/modelPick" },
        "escalation":  { "$ref": "#/$defs/modelPick" }
      }
    },
    "tool_whitelist": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "tool_blacklist": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "max_turns": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "latency_budget_ms": {
      "type": "integer",
      "minimum": 1
    },
    "confidence_offset": {
      "type": "number",
      "description": "Per §6.5 — model-specific calibration adjustment to variant thresholds.",
      "minimum": -1,
      "maximum": 1
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1
    }
  },
  "$defs": {
    "modelPick": {
      "type": "object",
      "required": ["tier", "model"],
      "additionalProperties": false,
      "properties": {
        "tier":  { "enum": ["local", "cloud"] },
        "model": { "type": "string", "minLength": 1 }
      }
    }
  }
}
