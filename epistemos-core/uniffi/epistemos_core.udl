namespace epistemos_core {
    // ── Vault Analysis ──────────────────────────────────────────────────────

    /// Bi-directional MTLD lexical diversity score.
    /// High MTLD (>100) → rich vocabulary → higher LoRA rank needed.
    /// Low MTLD (<50) → limited vocabulary → lower rank sufficient.
    double compute_mtld(sequence<string> tokens, double threshold);

    /// Tokenize text for MTLD computation (lowercase, alphanumeric + hyphens).
    sequence<string> tokenize_for_mtld(string text);

    /// Dual-bound token estimation: max(chars/3.5, words*1.33).
    /// Replaces the existing 1.3x word multiplier.
    u64 estimate_tokens(string content);

    /// BLAKE3 content hash for incremental analysis caching.
    string content_hash(string content);

    /// BLAKE3 hash of raw bytes for file integrity verification.
    /// Zero-corruption spec §2.2.
    string content_hash_bytes(sequence<u8> content);

    /// Verify content against a previously computed BLAKE3 hash.
    /// Returns true if matches, false if corrupted.
    /// Zero-corruption spec §2.3.
    boolean verify_content_hash(sequence<u8> content, string expected_hash);

    // ── NFC Normalization (zero-corruption spec §5.1) ──────────────────────

    /// Normalize text to Unicode NFC form.
    /// All text entering the database must pass through this.
    string normalize_to_nfc(string input);

    /// Sanitize and normalize text from external sources.
    /// Throws on rejection (null bytes, replacement chars, mid-string BOMs).
    [Throws=TextNormalizationError]
    string sanitize_and_normalize(string input);

    // ── Corrupted File Recovery ────────────────────────────────────────────

    /// Classify likely corruption markers in decoded text.
    CorruptionAnalysis classify_corruption(string text, string source_encoding);

    /// Try common mojibake repair chains against raw bytes.
    sequence<RepairCandidate> repair_mojibake(sequence<u8> content);

    /// Split a binary blob into padding and text regions using the provided encoding.
    BinaryTextExtraction extract_text_from_binary(sequence<u8> content, string encoding_label);

    // ── Durable Filesystem (zero-corruption spec §1.1) ──────────────────────

    /// F_FULLFSYNC on a file descriptor. Returns 0 on success, -1 on failure.
    /// The ONLY durable flush on macOS — fsync() does NOT flush drive cache.
    i32 full_sync_fd(i32 fd);

    /// Classify a document as prose/source_code/technical_docs/mixed_media.
    DocumentClassification classify_document(string content);

    /// Filter boilerplate from content. Returns cleaned text, removed byte count, and JSON array of section names removed.
    BoilerplateResult filter_boilerplate(string content);

    /// Chunk a markdown document by headers. Returns JSON array of chunks with heading hierarchy.
    /// Each chunk carries a hierarchy prefix (e.g. "# Top > ## Sub > ### Detail").
    /// Min 50 tokens, max 2048 tokens. Orphans merged, oversized split at paragraph boundaries.
    ChunkDocumentResult chunk_document(string content);

    // ── Quality Filter ────────────────────────────────────────────────────

    /// Deduplicate texts using MinHash near-duplicate detection.
    /// texts_json: JSON array of strings. threshold: Jaccard similarity threshold (0.0-1.0).
    DedupResult dedup_texts(string texts_json, double threshold);

    /// Score a training pair's quality based on text characteristics.
    /// Returns score (0-1) and whether it passes the minimum threshold.
    QualityScore score_training_pair(string instruction, string response, double min_score);

    // ── Adapter Routing ───────────────────────────────────────────────────

    /// Classify a prompt to determine which adapter type to route to.
    /// Returns adapter_type ("knowledge", "style", "tool", "general") and confidence.
    RoutingDecision route_prompt(string prompt);

    // ── Auto-Tuning ─────────────────────────────────────────────────────────

    /// Data-aware LoRA rank selection from MTLD + token count.
    u32 select_lora_rank(double mtld_score, u64 total_tokens);

    /// LoRA alpha selection from rank + dataset size.
    u32 select_lora_alpha(u32 rank, u64 dataset_size);

    /// Generate a complete auto-tuned training config.
    AutoTuneConfig auto_tune(
        u64 dataset_size,
        double mtld_score,
        u64 total_tokens,
        double model_size_b,
        u32 available_memory_mb,
        string profile
    );

    // ── Instant Recall (Ω18) ──────────────────────────────────────────────

    /// Create a new instant recall index with the given handle name.
    boolean instant_recall_create(string handle);

    /// Encode text and insert into the index under the given doc_id.
    boolean instant_recall_insert(string handle, string doc_id, string text);

    /// Remove a document from the index.
    boolean instant_recall_remove(string handle, string doc_id);

    /// Search for notes similar to query_text. Returns JSON array of results.
    string instant_recall_search(string handle, string query_text, u32 top_k);

    /// Get the number of documents in the index.
    u64 instant_recall_count(string handle);

    /// Clear all documents from the index.
    boolean instant_recall_clear(string handle);

    /// Encode text to a float32 embedding. Returns JSON array of floats.
    string instant_recall_encode(string text);

    // ── SSM State Persistence (Mamba vault memory) ─────────────────────────

    /// Save SSM hidden state to flat binary file. Returns the file path.
    /// vault_root: directory for state storage.
    /// model_id, session_id: identifiers for scoping.
    /// layer_count, state_dim, head_dim: tensor dimensions.
    /// vault_id_hash, model_id_hash: pre-computed hashes for scoping.
    /// has_conv_state: whether conv state is interleaved.
    /// layer_data: raw f16 tensor bytes.
    [Throws=SSMStateError]
    string ssm_save_state(
        string vault_root,
        string model_id,
        string session_id,
        u32 layer_count,
        u32 state_dim,
        u32 head_dim,
        u64 vault_id_hash,
        u64 model_id_hash,
        boolean has_conv_state,
        sequence<u8> layer_data
    );

    /// Load SSM hidden state from a file. Returns JSON metadata + base64 layer data.
    [Throws=SSMStateError]
    string ssm_load_state(string file_path);

    /// List all saved SSM states. Returns JSON array of metadata.
    /// model_hash_filter: if non-zero, filter to this model only.
    [Throws=SSMStateError]
    string ssm_list_states(string vault_root, u64 model_hash_filter);

    /// Prune old SSM states, keeping most recent keep_count.
    /// model_hash_filter: if non-zero, prune only this model.
    [Throws=SSMStateError]
    u32 ssm_prune_states(string vault_root, u64 model_hash_filter, u32 keep_count);

    /// Compute stable u64 hash for vault path scoping.
    u64 ssm_hash_vault_path(string vault_root);

    /// Compute stable u64 hash for model identity.
    u64 ssm_hash_model_id(string model_id);

    // ── Scheduling ──────────────────────────────────────────────────────────

    /// Evaluate whether training should run and at which tier.
    TrainingDecision evaluate_schedule(
        u64 dirty_file_count,
        i64 days_since_micro,
        i64 days_since_deep,
        u32 current_hour,
        u32 current_weekday,
        boolean is_on_battery,
        boolean is_training
    );
};

interface AgentSession {
    constructor(string session_id, string transcript_root);
    AgentTurnResult run_scaffold_turn(string user_message);
    boolean set_provider_api_key(string provider, string api_key);
    AgentTurnResult run_live_routed_turn(string user_message);
    AgentTurnResult run_live_provider_turn(string user_message, string provider);
    sequence<AgentEvent> drain_events();
    string transcript_path();
    string transcript_jsonl();
    string runtime_blueprint_json();
    string route_objective_json(string objective);
};

[Enum]
interface SerialFallbackMode {
    Resident();
    SsdStreaming();
};

dictionary SerialInferenceSnapshot {
    string phase;
    SerialFallbackMode fallback_mode;
    boolean should_stream_experts_from_ssd;
    boolean turn_boundary_readahead_allowed;
    boolean expert_prefetch_allowed;
    u64 turn_index;
    u64 available_memory_bytes;
    u64 non_expert_resident_bytes;
};

// ── Exported Types ──────────────────────────────────────────────────────────

dictionary AutoTuneConfig {
    u32 lora_rank;
    u32 lora_alpha;
    u32 epochs;
    u32 max_iters;
    u32 batch_size;
    double learning_rate;
    double warmup_ratio;
    double weight_decay;
    u32 max_seq_length;
    u32 estimated_memory_mb;
    sequence<string> target_modules;
    string adapter_type;
};

[Enum]
interface TrainingTier {
    None();
    MicroTraining();
    DeepRetraining();
    UserTriggered();
};

dictionary TrainingDecision {
    boolean should_train;
    TrainingTier tier;
    string reason;
    u64 dirty_file_count;
    i64 days_since_last;
};

dictionary DocumentClassification {
    string doc_type;
    double code_prose_ratio;
    double confidence;
    u64 line_count;
    boolean has_frontmatter;
};

dictionary BoilerplateResult {
    string cleaned;
    u64 removed_bytes;
    string sections_removed_json;
};

dictionary ChunkDocumentResult {
    string chunks_json;
    u32 chunk_count;
    u64 total_tokens;
};

dictionary CorruptionAnalysis {
    string classification;
    string detail;
    double replacement_ratio;
    double null_density;
    string likely_true_encoding;
    u64 first_problem_offset;
};

dictionary RepairCandidate {
    string chain;
    string repaired_text;
    double score;
};

dictionary BinaryTextRegion {
    u64 offset;
    u64 length;
    string decoded;
    sequence<u8> raw_bytes;
    boolean is_padding;
};

dictionary BinaryTextExtraction {
    sequence<BinaryTextRegion> regions;
    string readable_text;
};

dictionary DedupResult {
    string keep_indices_json;
    u32 duplicate_count;
    u32 unique_count;
};

dictionary QualityScore {
    double score;
    boolean passes;
    string reason;
};

dictionary RoutingDecision {
    string adapter_type;
    double confidence;
};

dictionary AgentEvent {
    u64 sequence;
    string phase;
    string payload;
    string timestamp;
};

dictionary AgentTurnResult {
    string session_id;
    string stop_reason;
    string assistant_text;
    u32 turn_count;
    u32 emitted_event_count;
    string transcript_path;
};

[Error]
enum TextNormalizationError {
    "ContainsNullByte",
    "ContainsReplacementCharacter",
    "ContainsMidStringBom"
};

[Error]
enum SSMStateError {
    "Io",
    "InvalidFormat"
};

[Error]
enum SerialInferenceTransitionError {
    "InvalidTransition",
    "TurnBoundaryOnly",
    "GpuComputeActive",
    "NoOpenTurn"
};

interface SerialInferenceController {
    constructor(
        u64 pressure_threshold_bytes,
        u64 recovery_threshold_bytes,
        u64 non_expert_resident_bytes
    );
    void update_available_memory(u64 available_bytes);
    [Throws=SerialInferenceTransitionError]
    void begin_turn();
    [Throws=SerialInferenceTransitionError]
    void end_turn();
    [Throws=SerialInferenceTransitionError]
    void record_turn_boundary_readahead();
    [Throws=SerialInferenceTransitionError]
    void begin_ssd_read();
    [Throws=SerialInferenceTransitionError]
    void finish_ssd_read();
    [Throws=SerialInferenceTransitionError]
    void begin_gpu_compute();
    [Throws=SerialInferenceTransitionError]
    void finish_gpu_compute();
    SerialInferenceSnapshot snapshot();
};

[Enum]
interface RuntimeKind {
    Gguf();
    Mlx();
    Remote();
};

[Enum]
interface ExecutionMode {
    Local();
    Remote();
    Hybrid();
};

[Enum]
interface ReasoningProfile {
    Standard();
    Deep();
    Adaptive();
    Experimental();
    VisualSidecar();
};

[Enum]
interface RuntimeOperation {
    Generate();
    Embed();
    Adapt();
    ImageGenerate();
};

[Enum]
interface GenerationEventKind {
    Started();
    Token();
    Status();
    ToolStatus();
    Summary();
    Completed();
    Failed();
    Cancelled();
};

// ── Phase 2: Compute Steering Types ─────────────────────────────────────────

[Enum]
interface ComputeProfile {
    Standard();
    DeepGraph();
    Adaptive();
    Experimental();
    VisualSidecar();
};

[Enum]
interface ExpertBudgetClass {
    Default();
    Constrained();
    Deep();
};

[Enum]
interface KVPolicyKind {
    Baseline();
    Compressed();
    Blocked();
};

dictionary ComputeBudget {
    u64? max_wall_ms;
    u32? max_tokens;
    u64? max_io_bytes;
    u32? max_adapt_steps;
    u32? max_aux_calls;
};

// ── End Phase 2 Compute Steering Types ──────────────────────────────────────

[Error]
enum RuntimeContractError {
    "ModelNotFound",
    "ModelNotLoaded",
    "UnsupportedCapability",
    "Timeout",
    "Cancelled",
    "PolicyDenied",
    "RuntimeUnavailable",
    "MemoryPressure",
    "InvalidTransition",
    "BackendFailure",
    "ContractViolation"
};

dictionary RuntimePolicy {
    sequence<RuntimeKind> available_runtime_kinds;
    RuntimeKind primary_generation_runtime_kind;
    boolean allow_mlx_generation_fallback;
    sequence<ReasoningProfile> allowed_reasoning_profiles;
    ReasoningProfile default_reasoning_profile;
};

dictionary RuntimeModelLoadRequest {
    RuntimeKind? requested_runtime_kind;
    ExecutionMode execution_mode;
    string model_id;
    string? artifact_id;
};

dictionary RuntimeModelHandle {
    string handle_id;
    RuntimeKind runtime_kind;
    ExecutionMode execution_mode;
    string model_id;
    string? artifact_id;
};

dictionary RuntimeGenerationStreamOptions {
    boolean include_status_events;
};

dictionary RuntimeHandshakeRequest {
    RuntimeKind? requested_runtime_kind;
    ExecutionMode execution_mode;
    RuntimeOperation operation;
    ReasoningProfile? reasoning_profile;
    string? execution_policy_ref;
};

dictionary RuntimeHandshake {
    RuntimeKind? requested_runtime_kind;
    RuntimeKind resolved_runtime_kind;
    ReasoningProfile? requested_reasoning_profile;
    ReasoningProfile? resolved_reasoning_profile;
    string? execution_policy_id;
    RuntimeCapabilities capabilities;
    boolean used_fallback_resolution;
};

dictionary RuntimeGenerationRequest {
    string request_id;
    RuntimeKind? requested_runtime_kind;
    ExecutionMode execution_mode;
    string model_id;
    string? artifact_id;
    string? model_handle_id;
    string prompt;
    string? system_prompt;
    u32 max_output_tokens;
    double temperature;
    sequence<string> stop_sequences;
    string? tool_policy_ref;
    string? context_ref;
    ReasoningProfile? reasoning_profile;
    string? execution_policy_ref;
    string? steering_hints_json;
    i32 priority;
    u32 timeout_ms;
    RuntimeGenerationStreamOptions stream_options;
};

dictionary RuntimeGenerationSummary {
    string request_id;
    RuntimeKind? requested_runtime_kind;
    RuntimeKind resolved_runtime_kind;
    ReasoningProfile? requested_reasoning_profile;
    ReasoningProfile resolved_reasoning_profile;
    ExecutionMode execution_mode;
    string model_id;
    string? artifact_id;
    string? execution_policy_id;
    string fallback_mode;
    double? time_to_first_token_ms;
    double total_duration_ms;
    double? tokens_per_second;
    u32 output_token_count;
    u32 output_character_count;
    string memory_pressure_state;
    string execution_phase;
    string masking_state;
    string kv_policy_state;
    string expert_budget_state;
    string adaptation_state;
    string guardrail_state;
    string sidecar_state;
    string budget_outcome;
    boolean plan_trace_present;
    boolean cancelled;
    RuntimeContractError? error_class;
};

dictionary RuntimeGenerationEvent {
    GenerationEventKind kind;
    string? text;
    string? status;
    RuntimeGenerationSummary? summary;
    RuntimeContractError? error_class;
    string? error_message;
};

dictionary RuntimeStatsTarget {
    string? model_handle_id;
    string? stream_handle;
};

dictionary RuntimeCapabilities {
    boolean supports_generate;
    boolean supports_embed;
    boolean supports_adapt;
    boolean supports_image_generate;
    boolean supports_structured_masking;
    boolean supports_dynamic_sparsity;
    boolean supports_speculative_decoding;
    boolean supports_streaming_from_ssd;
    boolean supports_kv_policy;
    boolean supports_expert_budgeting;
    boolean supports_serial_io_audit;
    boolean supports_tool_calls;
};

dictionary RuntimeStats {
    RuntimeKind? requested_runtime_kind;
    RuntimeKind? resolved_runtime_kind;
    ReasoningProfile? requested_reasoning_profile;
    ReasoningProfile? resolved_reasoning_profile;
    string? model_id;
    string? artifact_id;
    string? execution_policy_id;
    string? fallback_mode;
    string? memory_pressure_state;
    string? execution_phase;
    string masking_state;
    string kv_policy_state;
    string expert_budget_state;
    string adaptation_state;
    string guardrail_state;
    string sidecar_state;
    string budget_outcome;
    boolean plan_trace_present;
    ComputeProfile? compute_profile;
    ExpertBudgetClass? expert_budget_class;
    KVPolicyKind? kv_policy_kind;
    RuntimeCapabilities capabilities;
    boolean cancelled;
    boolean terminal_event_emitted;
};

interface RuntimeControlPlane {
    constructor(
        sequence<RuntimeKind> available_runtime_kinds,
        RuntimeKind primary_generation_runtime_kind,
        boolean allow_mlx_generation_fallback
    );
    void set_policy(RuntimePolicy policy);
    [Throws=RuntimeContractError]
    RuntimeModelHandle load_model(RuntimeModelLoadRequest request);
    [Throws=RuntimeContractError]
    void unload_model(string handle_id);
    [Throws=RuntimeContractError]
    string generate(RuntimeGenerationRequest request);
    [Throws=RuntimeContractError]
    RuntimeHandshake handshake(RuntimeHandshakeRequest request);
    [Throws=RuntimeContractError]
    void emit_started(string stream_handle);
    [Throws=RuntimeContractError]
    void emit_status(string stream_handle, string status);
    [Throws=RuntimeContractError]
    void emit_token(string stream_handle, string text);
    [Throws=RuntimeContractError]
    void emit_summary(string stream_handle, RuntimeGenerationSummary summary);
    [Throws=RuntimeContractError]
    void finish_completed(string stream_handle, RuntimeGenerationSummary summary);
    [Throws=RuntimeContractError]
    void finish_failed(
        string stream_handle,
        RuntimeContractError error_class,
        string error_message,
        RuntimeGenerationSummary? summary
    );
    [Throws=RuntimeContractError]
    void finish_cancelled(string stream_handle, RuntimeGenerationSummary? summary);
    [Throws=RuntimeContractError]
    void cancel(string stream_handle);
    [Throws=RuntimeContractError]
    RuntimeGenerationEvent? poll_event(string stream_handle);
    [Throws=RuntimeContractError]
    sequence<RuntimeGenerationEvent> poll_events(string stream_handle, u32 max_events);
    boolean close_stream(string stream_handle);
    [Throws=RuntimeContractError]
    RuntimeStats stats(RuntimeStatsTarget target);
    [Throws=RuntimeContractError]
    void embed();
    [Throws=RuntimeContractError]
    void adapt();
    [Throws=RuntimeContractError]
    void image_generate();
};

// ── Phase 3: Adaptation Subsystem Types ─────────────────────────────────────

[Error]
enum AdaptSessionError {
    "SessionNotFound",
    "InvalidTransition",
    "NormCapExceeded",
    "CanaryFailed",
    "BudgetExhausted",
    "ExperimentNotAvailable",
    "PolicyDenied",
    "InternalError"
};

dictionary AdaptSessionConfig {
    string adapt_target;
    string adapter_id;
    string model_id;
    u32 min_chunk_tokens;
    u32 max_update_count;
    u32 max_adapt_steps;
    double gradient_norm_cap;
    double canary_loss_threshold_multiplier;
};

dictionary AdaptUpdateResult {
    boolean accepted;
    double canary_loss;
    double anchor_divergence;
    double gradient_norm;
    boolean rollback_triggered;
    double duration_ms;
};

dictionary AdaptSessionSnapshot {
    string session_id;
    string state;
    string adapter_id;
    string model_id;
    u32 update_count;
    u32 accumulated_tokens;
    u32 rollback_count;
    double baseline_canary_loss;
    double last_canary_loss;
    double anchor_divergence;
    double total_duration_ms;
};

[Error]
enum SidecarSessionError {
    "SessionNotFound",
    "InvalidTransition",
    "CompressionFailed",
    "InternalError"
};

dictionary SidecarSessionSnapshot {
    string session_id;
    string state;
    u32 input_token_count;
    u32 compressed_token_count;
    double compression_ratio;
    double duration_ms;
};

interface AdaptationSubsystem {
    constructor();
    [Throws=AdaptSessionError]
    string begin_adapt_session(AdaptSessionConfig config);
    [Throws=AdaptSessionError]
    void submit_training_signal(string session_id, u32 token_count);
    [Throws=AdaptSessionError]
    void set_baseline_canary_loss(string session_id, double baseline_loss);
    [Throws=AdaptSessionError]
    void fire_update(string session_id);
    [Throws=AdaptSessionError]
    void report_update_result(string session_id, AdaptUpdateResult result);
    [Throws=AdaptSessionError]
    AdaptSessionSnapshot end_adapt_session(string session_id);
    [Throws=AdaptSessionError]
    AdaptSessionSnapshot adapt_session_snapshot(string session_id);
    boolean has_active_session();
    string active_session_adaptation_state();
    [Throws=SidecarSessionError]
    string begin_sidecar_compression(u32 input_token_count);
    [Throws=SidecarSessionError]
    void report_sidecar_result(string session_id, u32 compressed_token_count, double duration_ms);
    [Throws=SidecarSessionError]
    void report_sidecar_failure(string session_id);
    [Throws=SidecarSessionError]
    SidecarSessionSnapshot end_sidecar_session(string session_id);
    [Throws=SidecarSessionError]
    SidecarSessionSnapshot sidecar_session_snapshot(string session_id);
};
